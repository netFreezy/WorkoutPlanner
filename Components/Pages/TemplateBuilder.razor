@page "/templates/new"
@page "/templates/{Id:int}/edit"
@rendermode InteractiveServer

<PageTitle>@(isEditing ? "Edit Template" : "New Template")</PageTitle>

<div class="builder-page">
    <BuilderToolbar OnAddExercises="OpenExercisePicker"
                    OnSave="SaveTemplate"
                    OnDiscard="Discard"
                    OnUndo="Undo"
                    OnRedo="Redo"
                    CanUndo="State.CanUndo"
                    CanRedo="State.CanRedo"
                    HasUnsavedChanges="State.HasUnsavedChanges"
                    SelectedCount="SelectedCount"
                    HasWarmUp="@HasWarmUp"
                    HasCoolDown="@HasCoolDown"
                    OnAddWarmUp="AddWarmUpSection"
                    OnAddCoolDown="AddCoolDownSection"
                    OnGroupSuperset="GroupAsSuperset"
                    OnGroupEmom="GroupAsEmom"
                    OnUngroup="UngroupSelected"
                    CanUngroup="@CanUngroup" />

    <div class="builder-content">
        <input type="text" class="template-name-input" placeholder="Template name"
               @bind="State.Name" @bind:event="oninput" @onfocusout="OnNameChanged" />

        @if (showDescription)
        {
            <textarea class="template-description" placeholder="Description (optional)"
                      @bind="State.Description" @bind:event="oninput" rows="2"></textarea>
        }
        else
        {
            <button class="add-description-link" @onclick="() => showDescription = true">
                Add description
            </button>
        }

        <TagInput Tags="State.Tags" OnTagsChanged="OnTagsChanged" />

        <div class="exercise-list">
            @if (State.Items.Count == 0)
            {
                <div class="builder-empty">
                    <div class="builder-empty-icon">
                        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                            <path d="M12 8v8M8 12h8"/>
                        </svg>
                    </div>
                    <p class="builder-empty-heading">No exercises added</p>
                    <p class="builder-empty-body">Add exercises from your library to build this workout.</p>
                    <button class="builder-empty-action" @onclick="OpenExercisePicker">Add exercises</button>
                </div>
            }
            else
            {
                @foreach (var sectionType in GetVisibleSections())
                {
                    <SectionHeader Section="@sectionType"
                                   ExerciseCount="@(State.Items.Count(i => i.SectionType == sectionType))" />

                    @foreach (var entry in GetSectionEntries(sectionType))
                    {
                        @if (entry.Group != null)
                        {
                            <div class="group-container">
                                <GroupBracket Group="@entry.Group" ItemCount="@entry.Items.Count"
                                              OnParamsChanged="OnGroupParamsChanged" />
                                <div class="group-exercises">
                                    @foreach (var gi in entry.Items)
                                    {
                                        <ExerciseRow Item="gi" OnTargetChanged="OnTargetChanged"
                                                     OnRemove="RemoveExercise" OnSelectionChanged="OnSelectionChanged" />
                                    }
                                </div>
                            </div>
                        }
                        else
                        {
                            @foreach (var item in entry.Items)
                            {
                                <ExerciseRow Item="item" OnTargetChanged="OnTargetChanged"
                                             OnRemove="RemoveExercise" OnSelectionChanged="OnSelectionChanged" />
                            }
                        }
                    }
                }
            }
        </div>
    </div>

    <ExercisePickerDialog IsOpen="showExercisePicker"
                          OnClose="CloseExercisePicker"
                          OnExercisesSelected="AddSelectedExercises" />

    <Dialog IsOpen="showDiscardDialog" Title="Discard Changes" OnClose="CancelDiscard">
        <p class="discard-message">You have unsaved changes. Are you sure you want to discard them?</p>
        <div class="discard-footer">
            <button class="keep-btn" @onclick="CancelDiscard">Keep Editing</button>
            <button class="discard-btn" @onclick="ConfirmDiscard">Discard Changes</button>
        </div>
    </Dialog>

    <Toast @ref="toast" />

    <NavigationLock OnBeforeInternalNavigation="OnBeforeInternalNavigation"
                    ConfirmExternalNavigation="@State.HasUnsavedChanges" />
</div>
